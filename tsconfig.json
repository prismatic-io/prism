{
  "compilerOptions": {
    "strict": true,
    "sourceMap": false,
    "esModuleInterop": true,
    "declaration": false,
    "target": "ESNext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "verbatimModuleSyntax": true,
    "outDir": "./lib",
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src", "bin"],
  "exclude": [
    "src/commands/components/temp",
    "src/commands/components/init/temp",
    "src/commands/integrations/convert/temp",
    "templates",
    "**/*.test.ts"
  ]
}
